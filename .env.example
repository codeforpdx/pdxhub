# ──────────────────────────────────────────────────────────────────────────────
# PDX Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Portland Open Data / Socrata (optional — increases rate limits) ───────────
# Register for a free app token at https://data.portlandoregon.gov/
# Without a token the app still works but may be rate-limited after ~1000 req/day
SOCRATA_APP_TOKEN=

# ── TriMet (optional — higher rate limits) ────────────────────────────────────
# Free registration: https://developer.trimet.org/appid/registration/
# Without an App ID, some endpoints may return limited results
TRIMET_APP_ID=

# ── Oregon TripCheck (optional — keyed API access) ────────────────────────────
# The legacy public TripCheck alerts endpoint is deprecated. Use your issued
# TripCheck API primary key with the official portal operation once configured.
TRIPCHECK_PRIMARY_KEY=
